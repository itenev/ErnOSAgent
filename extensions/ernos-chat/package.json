{
  "name": "ernos-chat",
  "displayName": "Ern-OS",
  "description": "AI assistant — connects to your local Ern-OS agent engine",
  "version": "0.2.0",
  "publisher": "ernos",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Chat"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "ernos",
        "name": "ernos",
        "fullName": "Ern-OS Agent",
        "description": "Local AI assistant — powered by your Ern-OS engine",
        "isDefault": true
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ernos",
          "title": "Ern-OS",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "ernos": [
        {
          "type": "webview",
          "id": "ernos-chat",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      { "command": "ernos.sendSelection", "title": "Ern-OS: Send Selection" },
      { "command": "ernos.explainSelection", "title": "Ern-OS: Explain Selection" },
      { "command": "ernos.fixSelection", "title": "Ern-OS: Fix Selection" }
    ],
    "menus": {
      "editor/context": [
        { "command": "ernos.sendSelection", "group": "ernos@1" },
        { "command": "ernos.explainSelection", "group": "ernos@2" },
        { "command": "ernos.fixSelection", "group": "ernos@3" }
      ]
    }
  }
}
